# name: test_snapshot_positions_block
  '''
  from nodebpy import geometry as g, TreeBuilder
  
  with TreeBuilder("SnapPositions", arrange=None) as tree:
      geometry = tree.inputs.geometry("Geometry")
      geometry_1 = tree.outputs.geometry("Geometry")
  
      geometry >> g.SetPosition(offset=g.Position()) >> geometry_1
  
  # Restore authored node positions.
  tree.node_positions = {
      "Group Input": (0.0, 0.0),
      "Position": (100.0, 40.0),
      "Set Position": (200.0, 80.0),
      "Group Output": (300.0, 120.0),
  }
  '''
