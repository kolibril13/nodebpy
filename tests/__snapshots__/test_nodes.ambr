      N3("Vector"):::input-node
      N4("Integer"):::input-node
      N5("Noise Texture<br/><small>×5</small>"):::texture-node
      N6("Field to Grid"):::geometry-node
      N7("Grid Dilate & Erode"):::geometry-node
      N8("Grid Laplacian"):::geometry-node
      N9("Grid Dilate & Erode"):::geometry-node
      N10("Grid Gradient"):::geometry-node
      N11("Voxelize Grid"):::geometry-node
      N12("Grid Divergence"):::geometry-node
      N13("Grid Info"):::input-node
      N14("Group Output"):::default-node
      N0 -->|"Topology->Topology"| N6
      N1 -->|"Value->Float"| N6
      N2 -->|"Boolean->Boolean"| N6
      N3 -->|"Vector->Vector"| N6
      N4 -->|"Integer->idx"| N6
